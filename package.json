{
  "name": "portfolio-angular",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "serve:ssr:portfolio-angular": "node dist/portfolio-angular/server/server.mjs",
    "clean": "rimraf .angular/cache node_modules/.vite",
    "clean:all": "rimraf .angular node_modules package-lock.json && npm install",
    "clean:dist": "rimraf dist",
    "reset": "npm run clean:all && npm run start"
  },
  "private": true,
  "packageManager": "npm@11.17.0",
  "dependencies": {
    "@angular/animations": "^22.0.3",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/platform-server": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@angular/ssr": "^22.0.0",
    "express": "^5.1.0",
    "resize-observer-polyfill": "^1.5.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "vanilla-tilt": "^1.8.1",
    "zone.js": "^0.16.2"
  },
  "devDependencies": {
    "@angular/build": "^22.0.4",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@tailwindcss/postcss": "^4.3.1",
    "@types/express": "^5.0.1",
    "@types/node": "^20.17.19",
    "@types/vanilla-tilt": "^1.4.1",
    "autoprefixer": "^10.4.20",
    "jsdom": "^28.0.0",
    "postcss": "^8.4.49",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "tailwindcss": "^3.4.17",
    "typescript": "~6.0.2",
    "vitest": "^4.0.8"
  }
}
